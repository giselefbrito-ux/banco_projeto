 CREATE TABLE IF NOT EXISTS usuario (
    id_usuario INTEGER PRIMARY KEY,
    nome TEXT NOT NULL,
    email TEXT NOT NULL,
    senha TEXT NOT NULL,
    telefone TEXT NOT NULL
  );

  CREATE TABLE IF NOT EXISTS auditoria_usuario (
    id_auditoria_usuario INTEGER PRIMARY KEY,
    tipo_acao TEXT, 
    data_hora TEXT,
    descricao_acao TEXT,
    id_usuario_afetado INTEGER,
     FOREIGN KEY (id_usuario_afetado) REFERENCES usuario(id_usuario) 
  );

 CREATE TABLE IF NOT EXISTS usuario_mercado (
    id_usuario_mercado INTEGER PRIMARY KEY,
    cpnj TEXT, 
    segmento TEXT,
    nome_fantasia TEXT,
    FOREIGN KEY (id_usuario_mercado) REFERENCES usuario(id_usuario) 
  );

   CREATE TABLE IF NOT EXISTS usuario_pessoa(
    id_usuario_pessoa INTEGER PRIMARY KEY,
    cpf TEXT, 
    data_nascimento TEXT,
    FOREIGN KEY (id_usuario_pessoa) REFERENCES usuario(id_usuario) 
  );

   CREATE TABLE IF NOT EXISTS instituicao_receptora(
    id_usuario_receptor INTEGER PRIMARY KEY,
    cnpj TEXT, 
    tipo_instituicao TEXT,
    status TEXT,
    FOREIGN KEY (id_usuario_receptor) REFERENCES usuario(id_usuario) 
  );

   CREATE TABLE IF NOT EXISTS solicitacao_doacao (
    id_solicitacao INTEGER PRIMARY KEY,
    descricao TEXT, 
    data_solicitacao TEXT,
    status_solicitacao TEXT,
    id_usuario_solicitacao INTEGER,
    FOREIGN KEY (id_usuario_solicitacao) REFERENCES instituicao_receptora(id_usuario_receptor) 
  );

  CREATE TABLE IF NOT EXISTS produto_categoria(
    id_categoria INTEGER PRIMARY KEY,
    nome_categoria TEXT 
  );

  CREATE TABLE IF NOT EXISTS produto(
    id_produto INTEGER PRIMARY KEY,
    nome_produto TEXT,
    id_usuario INTEGER,
    id_usuario_produto INTEGER,
    id_categoria_produto INTEGER,
    FOREIGN KEY (id_usuario_produto) REFERENCES usuario(id_usuario),
    FOREIGN KEY (id_categoria_produto) REFERENCES produto_categoria(id_categoria)
  );

  CREATE TABLE IF NOT EXISTS lote(
    id_lote INTEGER PRIMARY KEY,
    quantidade INTEGER,
    data_validade TEXT,
    data_entrada TEXT,
    data_fabricacao TEXT,
    id_produto_lote INTEGER,
    FOREIGN KEY (id_produto_lote) REFERENCES produto(id_produto)
  );

  CREATE TABLE IF NOT EXISTS alerta_validade(
    id_alerta INTEGER PRIMARY KEY,
    dias_restantes INTEGER,
    status_alerta TEXT,
    data_alerta TEXT,
    mensagem TEXT,
    id_lote_alerta INTEGER,
    FOREIGN KEY (id_lote_alerta) REFERENCES lote(id_lote)
  );

CREATE TABLE item_doacao(
  id_item_doacao INTEGER PRIMARY KEY,
  item_doacao TEXT,
  quantidade INTEGER,
  id_doacao INTEGER,
  id_lote INTEGER,
  FOREIGN KEY (id_lote) REFERENCES lote(id_lote),
  FOREIGN KEY (id_doacao) REFERENCES doacao(id_doacao)
)
